rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    function isAdminOrMaster() {
      return hasRole('ADMIN') || hasRole('MASTER');
    }

    match /users/{userId} {
      allow read: if true; // necessário para carregar perfil no login
      allow create: if isAdminOrMaster();
      allow update: if isOwner(userId) || isAdminOrMaster();
      allow delete: if hasRole('MASTER');
    }

    match /pontos/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdminOrMaster();
      allow delete: if hasRole('MASTER');
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdminOrMaster();
      allow delete: if isAdminOrMaster();
    }

    match /cash_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdminOrMaster();
      match /events/{eventId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow delete: if isAdminOrMaster();
      }
    }

    match /shortages/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdminOrMaster();
    }

    match /locations/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrMaster();
    }

    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrMaster();
    }

    match /conferences/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /access_attempts/{docId} {
      allow create: if true;
      allow read, update: if hasRole('MASTER');
      allow delete: if hasRole('MASTER');
    }
  }
}
